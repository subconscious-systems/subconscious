{
  "name": "@subcon/e2b-cli",
  "version": "0.1.10",
  "displayName": "E2B CLI Agent",
  "private": false,
  "type": "module",
  "description": "CLI-first autonomous agent using Subconscious + E2B cloud sandboxes",
  "subconscious": {
    "language": "typescript",
    "framework": "E2B",
    "tags": ["typescript", "cli", "local"],
    "envVars": {
      "SUBCONSCIOUS_API_KEY": { "required": true },
      "E2B_API_KEY": { "required": true, "url": "https://e2b.dev" }
    }
  },
  "setup": [
    "bun install",
    "export SUBCONSCIOUS_API_KEY=your_key",
    "export E2B_API_KEY=your_e2b_key",
    "bun run agent"
  ],
  "main": "dist/index.js",
  "bin": {
    "e2b-cli": "dist/index.js",
    "subcon-e2b": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "agent": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --minify",
    "postbuild": "node scripts/postbuild.cjs",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests"
  },
  "keywords": [
    "agent",
    "subconscious",
    "e2b",
    "cli"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "subconscious": ">=0.2.0",
    "@e2b/sdk": "^2.0.0",
    "localtunnel": "^2.0.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/localtunnel": "^2.0.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
