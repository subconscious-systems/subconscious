{
  "name": "subconscious-vercel-template",
  "displayName": "Subconscious Vercel Template",
  "version": "1.0.0",
  "private": true,
  "setup": [
    "npm install",
    "cp .env.example .env.local",
    "Set SUBCONSCIOUS_API_KEY in .env.local",
    "npm run dev"
  ],
  "scripts": {
    "dev": "node scripts/dev-tunnel.mjs",
    "dev:no-tunnel": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "subconscious": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cloudflared": "^0.7.1",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
