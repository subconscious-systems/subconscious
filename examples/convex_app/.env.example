VITE_CONVEX_URL=

# Setup:
# 1. npm install
# 2. npx convex dev (generates convex/_generated/ and .env.local with VITE_CONVEX_URL)
# 3. In Convex Dashboard > Settings > Environment Variables, set:
#    SUBCONSCIOUS_API_KEY = your_key   (backend-only — not in this file)
# 4. npm run dev (in a new terminal while convex dev keeps running)
