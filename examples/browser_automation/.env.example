SUBCONSCIOUS_API_KEY=your_key

# Pick ONE browser backend. Either set BROWSER_PROVIDER explicitly, or just fill
# in the keys for one provider and it will be auto-detected.

# --- Browserbase (default) --- https://browserbase.com
BROWSER_PROVIDER=browserbase
BROWSERBASE_API_KEY=your_browserbase_key
# Optional — inferred from the API key. Set only if your account has multiple projects.
# BROWSERBASE_PROJECT_ID=your_browserbase_project_id

# --- Kernel --- https://onkernel.com
# BROWSER_PROVIDER=kernel
# KERNEL_API_KEY=your_kernel_key
