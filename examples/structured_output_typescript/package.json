{
  "name": "structured_output_typescript",
  "version": "1.0.0",
  "displayName": "Structured Output (TypeScript)",
  "description": "Get type-safe structured responses from Subconscious agents using Zod schemas",
  "type": "module",
  "subconscious": {
    "language": "typescript",
    "framework": "Zod Schema",
    "tags": ["local"],
    "envVars": {
      "SUBCONSCIOUS_API_KEY": { "required": true }
    }
  },
  "setup": [
    "npm install",
    "export SUBCONSCIOUS_API_KEY=your_key",
    "npx tsx main.ts"
  ],
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.0",
    "openai": "^6.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
