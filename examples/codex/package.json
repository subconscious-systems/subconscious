{
  "name": "codex-subconscious",
  "version": "0.1.0",
  "displayName": "Codex + Subconscious",
  "description": "Run the Codex CLI on your hosted Subconscious model via a custom OpenAI-compatible provider.",
  "subconscious": {
    "language": "shell",
    "framework": "Codex",
    "category": "coding-agent",
    "tags": ["local", "cli", "agents"],
    "envVars": {
      "SUBCONSCIOUS_API_KEY": { "required": true, "url": "https://subconscious.dev/platform" }
    },
    "agent": {
      "id": "codex",
      "name": "Codex CLI",
      "protocol": "openai",
      "install": "npm i -g @openai/codex",
      "launch": "codex -c model_providers.subconscious.name=Subconscious -c model_providers.subconscious.base_url=https://api.subconscious.dev/v1 -c model_providers.subconscious.env_key=SUBCONSCIOUS_API_KEY -c model_provider=subconscious -c model=subconscious/tim-qwen3.6-27b",
      "env": {
        "SUBCONSCIOUS_API_KEY": "your_key"
      }
    }
  },
  "setup": [
    "export SUBCONSCIOUS_API_KEY=your_key",
    "codex -c model_providers.subconscious.name=Subconscious -c model_providers.subconscious.base_url=https://api.subconscious.dev/v1 -c model_providers.subconscious.env_key=SUBCONSCIOUS_API_KEY -c model_provider=subconscious -c model=subconscious/tim-qwen3.6-27b"
  ]
}
