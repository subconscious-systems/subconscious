{
  "name": "codex-subconscious",
  "version": "0.1.0",
  "displayName": "Codex + Subconscious",
  "description": "Run the Codex CLI on your hosted Subconscious model via a custom OpenAI-compatible provider.",
  "subconscious": {
    "language": "shell",
    "framework": "Codex",
    "category": "coding-agent",
    "tags": ["local", "cli", "agents"],
    "envVars": {
      "SUBCONSCIOUS_API_KEY": { "required": true, "url": "https://subconscious.dev/platform" }
    },
    "agent": {
      "id": "codex",
      "name": "Codex CLI",
      "protocol": "openai",
      "install": "npm i -g @openai/codex",
      "launch": "codex",
      "env": {
        "SUBCONSCIOUS_API_KEY": "your_key"
      }
    }
  },
  "setup": [
    "export SUBCONSCIOUS_API_KEY=your_key",
    "export CODEX_HOME=$(mktemp -d)",
    "printf 'model = \"subconscious/tim-qwen3.6-27b\"\\nmodel_provider = \"subconscious\"\\n[model_providers.subconscious]\\nname = \"Subconscious\"\\nbase_url = \"https://api.subconscious.dev/v1\"\\nenv_key = \"SUBCONSCIOUS_API_KEY\"\\n' > \"$CODEX_HOME/config.toml\"",
    "codex"
  ]
}
