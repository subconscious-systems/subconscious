{
  "name": "opencode-subconscious",
  "version": "0.1.0",
  "displayName": "OpenCode + Subconscious",
  "description": "Run OpenCode on your hosted Subconscious model — registered as a custom provider, injected non-invasively (nothing written to your OpenCode config).",
  "subconscious": {
    "language": "shell",
    "framework": "OpenCode",
    "category": "coding-agent",
    "tags": ["local", "cli", "agents"],
    "envVars": {
      "SUBCONSCIOUS_API_KEY": { "required": true, "url": "https://subconscious.dev/platform" }
    },
    "agent": {
      "id": "opencode",
      "name": "OpenCode",
      "protocol": "openai",
      "install": "npm i -g opencode-ai",
      "launch": "opencode",
      "configEnv": "OPENCODE_CONFIG_CONTENT",
      "env": {
        "SUBCONSCIOUS_API_KEY": "your_key"
      }
    }
  },
  "setup": [
    "export SUBCONSCIOUS_API_KEY=your_key",
    "export OPENCODE_CONFIG_CONTENT='{\"$schema\":\"https://opencode.ai/config.json\",\"provider\":{\"subconscious\":{\"npm\":\"@ai-sdk/openai-compatible\",\"name\":\"Subconscious\",\"options\":{\"baseURL\":\"https://api.subconscious.dev/v1\",\"apiKey\":\"{env:SUBCONSCIOUS_API_KEY}\"},\"models\":{\"subconscious/tim-qwen3.6-27b\":{\"name\":\"Subconscious\",\"tools\":true}}}},\"model\":\"subconscious/subconscious/tim-qwen3.6-27b\"}'",
    "opencode"
  ]
}
